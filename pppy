n=list(map(int,input("Enter the nimber seperates by spaces").split()))
if 5 not in n:
    product =1
    for i in n:
        product*=1
        print(product)
else:
    index=n.index(5)
    right = n[index+1:]

    if len(right) == 0:
        print(-1)
    else:
        product = 1
        found = False
        for i in right:
            if i == 5:
                continue
            product *= i
            found = True

        if found:
            print(product)
        else:
            print(-1)
